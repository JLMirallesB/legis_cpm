---
import type { Lang, StructureNode } from '../lib/types';
import type { Promulgation } from '../lib/types';
import { getNavItemsWithGroups } from '../lib/disposition-groups';
import { t } from '../i18n/utils';

interface Props {
  structure: StructureNode[];
  lang: Lang;
  sidebarLabel?: string;
  promulgation?: Promulgation;
}

const { structure, lang, sidebarLabel, promulgation } = Astro.props;

const navItems = getNavItemsWithGroups(structure, lang);
const copyLabel = t('share.copy_link', lang);
---

<aside class="law-sidebar">
  <nav class="sidebar-nav" aria-label="Índice de la norma">
    {sidebarLabel && (
      <div class="sidebar-label">{sidebarLabel}</div>
    )}
    <ul>
      {navItems.map((item) => (
        <li class={`nav-item depth-${item.depth}${item.isGroup ? ' nav-group' : ''}`}>
          <a href={`#${item.id}`}>{item.title}</a>
          {!item.isGroup && (
            <button
              class="sidebar-link-btn"
              data-id={item.id}
              aria-label={copyLabel}
              title={copyLabel}
              type="button"
            >&#128279;</button>
          )}
        </li>
      ))}
      {promulgation && (
        <li class="nav-item depth-0">
          <a href="#promulgacion">{t('law.promulgation', lang)}</a>
          <button
            class="sidebar-link-btn"
            data-id="promulgacion"
            aria-label={copyLabel}
            title={copyLabel}
            type="button"
          >&#128279;</button>
        </li>
      )}
    </ul>
  </nav>
</aside>

<div id="sidebar-toast" class="sidebar-toast" aria-live="polite"></div>

<script define:vars={{ copiedMsg: t('share.link_copied', lang) }}>
  // ── Toast ──────────────────────────────────────────────
  function showToast(msg) {
    const toast = document.getElementById('sidebar-toast');
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add('visible');
    setTimeout(() => toast.classList.remove('visible'), 2000);
  }

  // ── Copy link buttons ───────────────────────────────────
  document.querySelectorAll('.sidebar-link-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const id = btn.getAttribute('data-id');
      const url = window.location.href.split('#')[0] + '#' + id;
      navigator.clipboard.writeText(url).then(() => showToast(copiedMsg)).catch(() => {
        // fallback
        const ta = document.createElement('textarea');
        ta.value = url;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        showToast(copiedMsg);
      });
    });
  });

  // ── Scroll spy + replaceState ───────────────────────────
  const links = document.querySelectorAll('.sidebar-nav a');
  const sections = Array.from(links).map((link) => {
    const id = link.getAttribute('href')?.replace('#', '');
    return id ? document.getElementById(id) : null;
  }).filter(Boolean);

  let ticking = false;
  function updateActive() {
    let current = '';
    for (const section of sections) {
      const rect = section.getBoundingClientRect();
      if (rect.top <= 120) current = section.id;
    }
    links.forEach((link) => {
      link.classList.toggle('active', link.getAttribute('href') === `#${current}`);
    });
    if (current) {
      history.replaceState(null, '', '#' + current);
    }
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(updateActive);
      ticking = true;
    }
  }, { passive: true });
  updateActive();
</script>

<style>
  .law-sidebar {
    position: sticky;
    top: calc(var(--header-height) + var(--space-md));
    max-height: calc(100vh - var(--header-height) - var(--space-xl));
    overflow-y: auto;
    padding-right: var(--space-md);
  }

  .sidebar-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-primary);
    padding: var(--space-xs) 8px var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-xs);
  }

  .sidebar-nav ul {
    list-style: none;
    padding: 0;
  }

  .nav-item {
    margin-bottom: 1px;
    position: relative;
    display: flex;
    align-items: center;
  }

  .nav-item a {
    display: block;
    flex: 1;
    padding: 4px 8px;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-left: 2px solid transparent;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    transition: all 0.15s;
    line-height: 1.4;
  }

  .nav-item a:hover {
    color: var(--color-primary);
    background: var(--color-bg-secondary);
    text-decoration: none;
  }

  .nav-item a.active {
    color: var(--color-primary);
    border-left-color: var(--color-primary);
    font-weight: 600;
    background: var(--color-bg-secondary);
  }

  .nav-group a {
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    color: var(--color-primary-dark);
    margin-top: var(--space-xs);
  }

  .depth-1 a { padding-left: 20px; }
  .depth-2 a { padding-left: 32px; }
  .depth-3 a { padding-left: 44px; }

  /* Copy-link button */
  .sidebar-link-btn {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.15s, color 0.15s;
    line-height: 1;
  }

  .nav-item:hover .sidebar-link-btn {
    opacity: 1;
  }

  .sidebar-link-btn:hover {
    color: var(--color-primary);
    background: var(--color-bg-secondary);
  }

  /* Toast */
  .sidebar-toast {
    position: fixed;
    bottom: 80px;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    background: var(--color-primary);
    color: #fff;
    padding: 6px 14px;
    border-radius: var(--radius-md);
    font-size: 0.82rem;
    font-family: var(--font-sans);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
    z-index: 9999;
    white-space: nowrap;
  }

  .sidebar-toast.visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 768px) {
    .law-sidebar {
      position: static;
      max-height: none;
      border-bottom: 1px solid var(--color-border);
      padding-bottom: var(--space-md);
      margin-bottom: var(--space-md);
    }
  }
</style>
