---
import type { Lang } from '../lib/types';
import { getLawsByCategory, getCategories } from '../lib/laws';
import { t } from '../i18n/utils';
import LawCard from './LawCard.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const categories = getCategories();
const lawsByCategory = getLawsByCategory(lang);
---

<section class="catalog">
  <nav class="category-nav" aria-label={lang === 'va' ? 'Categories' : 'Categorías'}>
    {categories.map((cat) => {
      const laws = lawsByCategory.get(cat.id);
      if (!laws || laws.length === 0) return null;
      return (
        <a href={`#cat-${cat.id}`} class="category-chip">{cat.label[lang]} ({laws.length})</a>
      );
    })}
  </nav>

  {categories.map((cat) => {
    const laws = lawsByCategory.get(cat.id);
    if (!laws || laws.length === 0) return null;

    return (
      <div class="category-section" id={`cat-${cat.id}`}>
        <h2 class="category-title">{cat.label[lang]}</h2>
        {cat.description?.[lang] && (
          <p class="category-desc">{cat.description[lang]}</p>
        )}
        <div class="law-grid">
          {laws.map((law) => (
            <LawCard law={law} lang={lang} />
          ))}
        </div>
      </div>
    );
  })}

  {lawsByCategory.size === 0 && (
    <p class="empty">{lang === 'va' ? "No hi ha legislació disponible encara." : "No hay legislación disponible todavía."}</p>
  )}
</section>

<style>
  .catalog {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .category-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .category-chip {
    display: inline-block;
    padding: var(--space-xs) var(--space-sm);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-primary);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .category-chip:hover {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
    text-decoration: none;
  }

  .category-section {
    scroll-margin-top: calc(var(--header-height) + var(--space-md));
  }

  .category-title {
    font-size: 1.2rem;
    color: var(--color-primary);
    margin-bottom: var(--space-xs);
    padding-bottom: var(--space-xs);
    border-bottom: 2px solid var(--color-border);
  }

  .category-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .law-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-md);
  }

  .empty {
    text-align: center;
    color: var(--color-text-muted);
    font-style: italic;
    padding: var(--space-2xl) 0;
  }
</style>
