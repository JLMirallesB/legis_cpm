---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

const lang = 'va' as const;
---

<BaseLayout lang={lang} title={t('search.results', lang)}>
  <div class="container search-page">
    <h1>{t('search.results', lang)}</h1>

    <div class="search-box">
      <form action={`${import.meta.env.BASE_URL}va/buscar/`} method="get">
        <input
          type="search"
          name="q"
          placeholder={t('search.placeholder', lang)}
          class="search-input"
          aria-label={t('nav.search', lang)}
        />
        <button type="submit" class="btn btn-primary">{t('nav.search', lang)}</button>
      </form>
    </div>

    <div class="results-area">
      <p class="coming-soon">El buscador estar&agrave; disponible pr&ograve;ximament. Per ara, navega el cat&agrave;leg des de la <a href={`${import.meta.env.BASE_URL}va/`}>p&agrave;gina principal</a>.</p>
    </div>
  </div>
</BaseLayout>

<style>
  .search-page {
    padding: var(--space-xl) 0;
    max-width: 800px;
  }

  h1 {
    font-size: 1.8rem;
    color: var(--color-primary);
    margin-bottom: var(--space-lg);
  }

  .search-box {
    margin-bottom: var(--space-xl);
  }

  .search-box form {
    display: flex;
    gap: var(--space-sm);
  }

  .search-input {
    flex: 1;
    padding: var(--space-sm) var(--space-md);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .search-input:focus {
    border-color: var(--color-primary);
  }

  .coming-soon {
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
